---
import StarlightPage from '@astrojs/starlight/components/StarlightPage.astro';
---

<StarlightPage frontmatter={{ title: 'Recherche IA' }}>
  <main class="max-w-4xl mx-auto p-8">
    <div class="bg-white p-8 rounded-xl shadow-lg border border-gray-100">
      <h1 class="text-4xl font-extrabold text-gray-900 mb-2 text-center">Recherche Intelligence Artificielle</h1>
      <p class="text-lg text-gray-600 mb-8 text-center">Posez votre question en français ou en anglais.</p>

      <div class="flex flex-col md:flex-row gap-4 mb-10">
        <input 
          type="text" 
          id="search-input" 
          placeholder="Ex: « Comment configurer MFA? »" 
          class="flex-1 p-4 text-lg border-2 border-gray-200 rounded-xl focus:border-blue-500 outline-none transition-all"
        />
        <button id="search-btn" class="bg-blue-600 text-white font-bold px-8 py-4 rounded-xl hover:bg-blue-700 shadow-md">
          Chercher
        </button>
      </div>

      <div id="results" class="space-y-6"></div>
    </div>
  </main>
</StarlightPage>

<script is:inline>
  window.addEventListener('load', () => {
    const btn = document.getElementById('search-btn');
    const input = document.getElementById('search-input');
    const resultsDiv = document.getElementById('results');

    async function performSearch() {
      const query = input.value.trim();
      if (!query) return;

      resultsDiv!.innerHTML = `<p class="text-center text-gray-500">Recherche en cours...</p>`;

      try {
        const response = await fetch('/api/search.json', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ query: query, language: 'all' })
        });

        const data = await response.json();

        const validMatches = data.results.filter((m) => m.score > 0.45);

        if (validMatches.length === 0) {
          resultsDiv!.innerHTML = '<p class="text-center text-gray-500">Aucun résultat trouvé.</p>';
          return;
        }

        resultsDiv!.innerHTML = validMatches.map((match: any) => {
          const cleanPath = match.metadata.url_path.startsWith('/') ? match.metadata.url_path : `/${match.metadata.url_path}`;
          const finalUrl = (cleanPath.startsWith('/en/') || cleanPath.startsWith('/fr/') || cleanPath.startsWith('/fr-ca/'))
            ? cleanPath
            : `/fr-ca${cleanPath}`;

          return `
            <div class="p-6 border border-gray-100 bg-gray-50 rounded-xl">
              <div class="flex justify-between items-start mb-2">
                <span class="text-xs font-bold text-blue-600 bg-blue-50 px-2 py-1 rounded">Score: ${Math.round(match.score * 100)}%</span>
                <a href="${finalUrl}" class="text-sm text-blue-500 hover:underline">Voir Doc →</a>
              </div>
              <p class="text-gray-800">${match.metadata.text}</p>
            </div>
          `;
        }).join('');
      } catch (error) {
        resultsDiv!.innerHTML = '<p class="text-red-500 text-center">Erreur de connexion.</p>';
      }
    }  // ← this was missing

    btn?.addEventListener('click', performSearch);
    input?.addEventListener('keypress', (e) => { if (e.key === 'Enter') performSearch(); });
  });
</script>