---
import StarlightPage from '@astrojs/starlight/components/StarlightPage.astro';
---

<StarlightPage frontmatter={{ title: 'AI Documentation Search', template: 'splash' }}>
  <main class="max-w-4xl mx-auto p-8">
    <div class="bg-white p-8 rounded-xl shadow-lg border border-gray-100">
      <h1 class="text-4xl font-extrabold text-gray-900 mb-2 text-center">AI Knowledge Base</h1>
      <p class="text-lg text-gray-600 mb-8 text-center">Ask a question to search through 112 bilingual technical chunks.</p>

      <div class="flex flex-col md:flex-row gap-4 mb-10">
        <input 
          type="text" 
          id="search-input" 
          placeholder="e.g., 'Comment configurer MFA?' or 'Loi 25 compliance'" 
          class="flex-1 p-4 text-lg border-2 border-gray-200 rounded-xl focus:border-blue-500 outline-none transition-all"
        />
        <button id="search-btn" class="bg-blue-600 text-white font-bold px-8 py-4 rounded-xl hover:bg-blue-700 transition-all shadow-md">
          Ask AI
        </button>
      </div>

      <div id="results" class="space-y-6">
        </div>
    </div>
  </main>
</StarlightPage>

<script>
  const btn = document.getElementById('search-btn');
  const input = document.getElementById('search-input') as HTMLInputElement;
  const resultsDiv = document.getElementById('results');

  async function performSearch() {
    const query = input.value.trim();
    if (!query) return;

    resultsDiv!.innerHTML = `
      <div class="flex flex-col items-center justify-center p-12">
        <div class="animate-spin rounded-full h-10 w-10 border-b-2 border-blue-600 mb-4"></div>
        <p class="text-gray-500 font-medium">Retrieving semantic matches...</p>
      </div>
    `;

    try {
      const response = await fetch('/api/search.json', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ 
          query: query,
          language: query.toLowerCase().includes('comment') || query.toLowerCase().includes('loi') ? 'fr-ca' : 'en' 
        })
      });

      const data = await response.json();

      if (!response.ok) {
        resultsDiv!.innerHTML = `<div class="p-4 bg-amber-50 text-amber-700 border border-amber-200 rounded-lg">${data.error}</div>`;
        return;
      }

      if (data.results.length === 0) {
        resultsDiv!.innerHTML = '<p class="text-center text-gray-500 italic">No matching documentation found.</p>';
        return;
      }

      resultsDiv!.innerHTML = data.results.map((match: any) => `
        <div class="p-6 border border-gray-100 bg-gray-50 rounded-xl hover:shadow-md transition-all">
          <div class="flex justify-between items-start mb-3">
            <span class="text-xs font-bold text-blue-600 bg-blue-50 px-2 py-1 rounded">
              Relevance: ${Math.round(match.score * 100)}%
            </span>
            <a href="${match.metadata.url_path}" class="text-sm text-blue-500 hover:underline">View Doc →</a>
          </div>
          <p class="text-gray-800">${match.metadata.text}</p>
        </div>
      `).join('');

    } catch (error) {
      resultsDiv!.innerHTML = '<p class="text-red-500 text-center">Failed to connect to the search engine.</p>';
    }
  }

  btn?.addEventListener('click', performSearch);
  input?.addEventListener('keypress', (e) => { if (e.key === 'Enter') performSearch(); });
</script>